{
  "name": "backorder-web-app",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node scripts/api-dev-server.js",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "tsc --noEmit",
    "test": "npm run check && node --check api/index.js && node --check scripts/api-dev-server.js && node -e \"require('./server/app'); require('./server/db/schema'); require('./server/services/products.service'); require('./server/services/notes.service')\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
