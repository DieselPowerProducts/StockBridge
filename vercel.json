{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**"
    },
    "api/cron/catalog-full-sync.js": {
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/catalog-full-sync",
      "schedule": "0 * * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(auth|backorders|status|import|notes|products|vendors)(.*)",
      "dest": "api/index.js"
    }
  ]
}
