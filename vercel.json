{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**",
      "maxDuration": 180
    },
    "api/cron/catalog-full-sync.js": {
      "includeFiles": "server/**",
      "maxDuration": 180
    },
    "api/cron/catalog-warehouse-sync.js": {
      "includeFiles": "server/**",
      "maxDuration": 180
    },
    "api/cron/auto-inventory.js": {
      "includeFiles": "server/**",
      "maxDuration": 180
    },
    "api/cron/gmail-watch.js": {
      "includeFiles": "server/**",
      "maxDuration": 60
    },
    "api/cron/shopify-availability-sync.js": {
      "includeFiles": "server/**",
      "maxDuration": 180
    }
  },
  "crons": [
    {
      "path": "/api/cron/catalog-warehouse-sync",
      "schedule": "0 0-3,13-23 * * *"
    },
    {
      "path": "/api/cron/catalog-full-sync",
      "schedule": "15 10 * * *"
    },
    {
      "path": "/api/cron/auto-inventory",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/gmail-watch",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/shopify-availability-sync",
      "schedule": "* * * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(audits|auth|backorders|status|email|import|integrations|notes|notifications|price-audit|products|shopify|users|vendors)(.*)",
      "dest": "api/index.js"
    }
  ]
}
